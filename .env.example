# ─────────────────────────────────────────────────────────────────
# CAP Infinity — Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
# Comma-separated list of allowed origins (CORS). Use * to allow all.
ALLOWED_ORIGINS=http://localhost:3000

# ── Anthropic Claude API ──────────────────────────────────────────
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model to use for AI features.
# Options: claude-opus-4-6 | claude-sonnet-4-6 | claude-haiku-4-5-20251001
ANTHROPIC_MODEL=claude-sonnet-4-6

# Max tokens the AI may return per response
ANTHROPIC_MAX_TOKENS=4096

# ── PostgreSQL Database ───────────────────────────────────────────
# The setup script creates this database automatically.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cap_infinity
DB_USER=cap_user
DB_PASSWORD=cap_password_change_me

# Connection pool size
DB_POOL_MAX=10
DB_POOL_IDLE_TIMEOUT=30000
DB_POOL_CONNECTION_TIMEOUT=2000

# ── Session / Security ────────────────────────────────────────────
# Random 32-char+ string used to sign session cookies.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change_me_to_a_long_random_secret_string

# ── Rate Limiting ─────────────────────────────────────────────────
# Max AI API calls per IP per 15-minute window
AI_RATE_LIMIT=50

# ── Logging ──────────────────────────────────────────────────────
# Options: combined | dev | tiny | none
LOG_FORMAT=dev
